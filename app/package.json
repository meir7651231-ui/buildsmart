{
  "name": "buildsmart",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BuildSmart — ניהול רכש, תקציב ומשימות לאתרי בנייה",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b --noEmit",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run build && cap sync ios && cap open ios",
    "cap:android": "npm run build && cap sync android && cap open android"
  },
  "dependencies": {
    "@fontsource/heebo": "^5.1.0",
    "@fontsource/rubik": "^5.1.0",
    "@preact/signals": "^1.3.0",
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.0",
    "playwright": "^1.60.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
