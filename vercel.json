{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "app_flutter/build/web",
  "framework": null,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/((?!assets/|canvaskit/|icons/|.*\\.(?:js|css|ico|svg|png|jpg|jpeg|webp|woff|woff2|webmanifest|wasm|json|map|ttf|otf|html)).*)",
      "destination": "/index.html"
    }
  ]
}
